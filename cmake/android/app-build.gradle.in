plugins {
    id 'com.android.application'
}

def releaseStoreFile = providers.gradleProperty("Q2RTX_RELEASE_STORE_FILE")
    .orElse(providers.environmentVariable("Q2RTX_RELEASE_STORE_FILE"))
def releaseStorePassword = providers.gradleProperty("Q2RTX_RELEASE_STORE_PASSWORD")
    .orElse(providers.environmentVariable("Q2RTX_RELEASE_STORE_PASSWORD"))
def releaseKeyAlias = providers.gradleProperty("Q2RTX_RELEASE_KEY_ALIAS")
    .orElse(providers.environmentVariable("Q2RTX_RELEASE_KEY_ALIAS"))
def releaseKeyPassword = providers.gradleProperty("Q2RTX_RELEASE_KEY_PASSWORD")
    .orElse(providers.environmentVariable("Q2RTX_RELEASE_KEY_PASSWORD"))
def debugKeystore = new File(System.getProperty("user.home"), ".android/debug.keystore")
def hasCustomReleaseSigning = releaseStoreFile.present &&
    releaseStorePassword.present &&
    releaseKeyAlias.present &&
    releaseKeyPassword.present

android {
    namespace 'com.nvidia.q2rtx'
    compileSdk 36

    signingConfigs {
        release {
            if (hasCustomReleaseSigning) {
                storeFile file(releaseStoreFile.get())
                storePassword releaseStorePassword.get()
                keyAlias releaseKeyAlias.get()
                keyPassword releaseKeyPassword.get()
            } else {
                // Keep local release installs working without a private keystore.
                storeFile debugKeystore
                storePassword 'android'
                keyAlias 'androiddebugkey'
                keyPassword 'android'
            }
        }
    }

    defaultConfig {
        applicationId "com.nvidia.q2rtx"
        minSdk 34
        targetSdk 36
        versionCode 1
        versionName "0.1.0"

        ndk {
            abiFilters 'arm64-v8a'
        }

        externalNativeBuild {
            cmake {
                abiFilters 'arm64-v8a'
                arguments "-DANDROID_STL=c++_static"
            }
        }
    }

    buildTypes {
        debug {
            jniDebuggable true
        }
        release {
            signingConfig signingConfigs.release
            minifyEnabled false
            proguardFiles getDefaultProguardFile('proguard-android-optimize.txt'), 'proguard-rules.pro'
        }
    }

    externalNativeBuild {
        cmake {
            path "jni/CMakeLists.txt"
            version "3.22.1"
        }
    }

    sourceSets {
        main {
            java.srcDirs += ["@Q2RTX_SDL_ANDROID_JAVA_DIR@"]
        }
    }

    packaging {
        jniLibs {
            useLegacyPackaging true
        }
    }
}

dependencies {
}

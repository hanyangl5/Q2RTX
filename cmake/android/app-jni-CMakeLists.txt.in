cmake_minimum_required(VERSION 3.22)

project(q2rtx_android C)

set(Q2RTX_ROOT "@Q2RTX_SOURCE_DIR_FOR_ANDROID@")

set(CMAKE_POLICY_DEFAULT_CMP0077 NEW)
set(USE_SYSTEM_SDL2 OFF CACHE BOOL "" FORCE)
set(USE_SYSTEM_OPENAL OFF CACHE BOOL "" FORCE)
set(CONFIG_GL_RENDERER OFF CACHE BOOL "" FORCE)
set(CONFIG_VKPT_RENDERER ON CACHE BOOL "" FORCE)
set(CONFIG_VKPT_ENABLE_DEVICE_GROUPS OFF CACHE BOOL "" FORCE)
set(CONFIG_VKPT_ENABLE_IMAGE_DUMPS OFF CACHE BOOL "" FORCE)
set(CONFIG_BUILD_GLSLANG OFF CACHE BOOL "" FORCE)
set(CONFIG_USE_CURL OFF CACHE BOOL "" FORCE)
set(CONFIG_LINUX_PACKAGING_SUPPORT OFF CACHE BOOL "" FORCE)
set(BUILD_SHARED_LIBS OFF CACHE BOOL "" FORCE)

if(NOT DEFINED GLSLANG_COMPILER)
    set(GLSLANG_COMPILER "glslangValidator" CACHE FILEPATH "Host glslangValidator executable" FORCE)
endif()

add_subdirectory("${Q2RTX_ROOT}" "${CMAKE_CURRENT_BINARY_DIR}/q2rtx")
